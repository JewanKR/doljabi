{
  "name": "react",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "gen:api": "openapi-typescript ../doljabi_engine/src/openapi.json -o src/api/schema.ts",
    "gen:ts-proto": "protoc --plugin=./node_modules/.bin/protoc-gen-ts_proto --ts_proto_out=src/ts-proto --ts_proto_opt=esModuleInterop=true,forceLong=bigint -I ../crates/doljabiproto/doljabiproto ../crates/doljabiproto/doljabiproto/*.proto",
    "gen:orval": "npx orval --config orval.config.ts"
  },
  "dependencies": {
    "@stripe/react-stripe-js": "5.6.0",
    "@supabase/supabase-js": "2.97.0",
    "@tanstack/react-query": "^5.90.21",
    "axios": "^1.13.5",
    "firebase": "12.9.0",
    "i18next": "^25.8.13",
    "i18next-browser-languagedetector": "^8.2.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^16.5.4",
    "react-router-dom": "^7.13.0",
    "recharts": "3.7.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react-swc": "^4.2.3",
    "autoprefixer": "^10.4.24",
    "eslint": "^10.0.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.0",
    "globals": "^17.3.0",
    "openapi-typescript": "^7.13.0",
    "orval": "^8.4.1",
    "postcss": "^8.5.6",
    "source-map": "^0.7.6",
    "tailwindcss": "^4.2.0",
    "ts-proto": "^2.11.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.0",
    "unplugin-auto-import": "^21.0.0",
    "vite": "^7.3.1"
  }
}
